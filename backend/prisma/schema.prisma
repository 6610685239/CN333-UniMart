// schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. User: เพิ่มข้อมูลยืนยันตัวตน
model User {
  id          Int       @id @default(autoincrement())
  email       String    @unique
  password    String    // เก็บ Password ที่เข้ารหัสแล้ว (Hash)
  name        String
  studentId   String?   // รหัสนักศึกษา (เอาไว้ยืนยันตัวตน)
  faculty     String?   // คณะ
  profileImage String?
  createdAt   DateTime  @default(now())

  products    Product[] // สินค้าที่ลงขาย
  favorites   Favorite[] // สินค้าที่กดถูกใจ
  // chat      Chat[]    // (อนาคต)
}

// 2. Product: เพิ่มรายละเอียดการขาย
model Product {
  id          Int       @id @default(autoincrement())
  title       String
  description String
  price       Float
  images      String[]  // เก็บรูปเป็น Array (เผื่อมีหลายรูป) [รองรับใน Postgres]
  condition   String    // สภาพสินค้า (มือหนึ่ง, มือสอง 90%)
  
  // สถานะสินค้า (ใช้ Enum)
  status      ProductStatus @default(AVAILABLE)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // ความสัมพันธ์
  ownerId     Int
  owner       User      @relation(fields: [ownerId], references: [id])
  
  categoryId  Int
  category    Category  @relation(fields: [categoryId], references: [id])
  
  favoritedBy Favorite[]
}

// 3. Category: หมวดหมู่สินค้า
model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique // เช่น 'Textbooks', 'Uniforms', 'Gadgets'
  products  Product[]
}

// 4. Favorite: ตารางเชื่อม User <-> Product
model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  productId Int
  product   Product  @relation(fields: [productId], references: [id])

  @@unique([userId, productId]) // ป้องกันการกดหัวใจซ้ำ
}

// Enum: ตัวเลือกสถานะที่ล็อกค่าไว้
enum ProductStatus {
  AVAILABLE // ว่าง
  RESERVED  // จองแล้ว
  SOLD      // ขายแล้ว
}